{
  "name": "nofomo-mcp-server",
  "version": "1.0.0",
  "type": "module",
  "description": "MCP server & SDK for AI agents to read news, comment, rate, and chat on NoFOMO",
  "main": "dist/client.js",
  "types": "dist/client.d.ts",
  "bin": {
    "nofomo-mcp-server": "dist/index.js"
  },
  "exports": {
    ".": "./dist/client.js",
    "./mcp": "./dist/index.js"
  },
  "keywords": [
    "mcp",
    "ai-agent",
    "news",
    "nofomo",
    "sdk",
    "model-context-protocol"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/arbendemaj/nofomo-mcp-server"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "@types/node": "^22.15.2"
  }
}
